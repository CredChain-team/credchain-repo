# ─────────────────────────────────────────────────────────────
# CredChain Backend — environment variables
# Copy this file to ".env" and fill in real values.
# ─────────────────────────────────────────────────────────────

# HTTP server
PORT=5000

# Allowed cross-origin frontend (CORS)
CLIENT_ORIGIN=http://localhost:3000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/credchain

# JSON Web Token signing secret
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google OAuth 2.0 (Sign in with Google — unified flow for all 3 roles)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must be exactly the GOOGLE_CALLBACK_URL below.
GOOGLE_CLIENT_ID=replace_me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_me_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Advanced systems
# Comma-separated emails allowed to run the Layer-4 issuer registry cross-match.
ADMIN_EMAILS=admin@credchain.io
# LEGACY: shared secret for the async KYC webhook (kept as fallback only — the
# primary L3 path is now the SYNCHRONOUS submitKyc + VerificationRouter below).
KYC_WEBHOOK_SECRET=replace_me_with_a_kyc_webhook_secret

# ── Verification providers (VerificationRouter) ──────────────────────────────
# Nigeria-first, country-routed. Leave BLANK to run in provisional/demo mode
# (funnel completes but every check is clearly flagged as not-real). Set a
# provider + its keys to go live. All are PAID per-check APIs.
#
# L1 entity legitimacy — CAC RC-number lookup (replaces WHOIS as the gate).
CAC_PROVIDER=            # dojah | verifyme | qoreid   (blank = manual review)
# CAC_API_KEY=... CAC_API_BASE=...  (per-provider; add when you wire the adapter)
#
# L3 officer identity + liveness — synchronous (no webhook/shared-secret vuln).
KYC_PROVIDER=            # smileid | veriff | trulioo   (blank = demo provisional)
# SMILEID_PARTNER_ID=... SMILEID_API_KEY=...
#
# L4 university registry — WAEC confirmation + NUC accredited allowlist.
WAEC_PROVIDER=           # waec   (blank = manual admin review)
NUC_ALLOWLIST_JSON=      # optional JSON array of accredited institution names
RDAP_ENABLED=false       # global L1 fallback (modern WHOIS replacement)
# How long a full L4 verification stays valid before re-attestation (no
# permanent badges).
ISSUER_VERIFICATION_TTL_DAYS=365
# Privacy policy version stamped on recorded consent (NDPA 2023 / GDPR).
PRIVACY_POLICY_VERSION=v1

# ── Payments (Strategy 2: licensed fiat escrow — CredChain never holds funds) ──
# A licensed partner holds funds IN TRUST in per-bounty virtual accounts and
# releases only on CredChain instruction. Leave BLANK for simulated escrow
# (MVP/demo). MUST be an escrow/trust product, NOT a collections product that
# settles into a CredChain-controlled account (that would re-trigger custody).
PAYMENTS_PROVIDER=       # flutterwave | korapay | moniepoint | providus
# FLUTTERWAVE_SECRET_KEY=...  KORAPAY_SECRET_KEY=...  (per-provider)
# Minimum escrow (Naira) required to mint a credential in production (anti-
# collusion skin-in-the-game). Ignored in DEMO_MODE (floor = 0).
MIN_BOUNTY_ESCROW_NAIRA=5000

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
# Path to the Devnet fee-payer wallet JSON (array of secret-key bytes).
# If unset, credential accept still works but skips the on-chain Memo write.
# NOTE: Solana is used ONLY to anchor credential proofs — never to hold money.
SOLANA_WALLET_PATH=./devnet-wallet.json

# Downstream AI microservices (proxied by the backend)
AI_CV_ENGINE_URL=http://localhost:8001
AI_INSIGHTS_ENGINE_URL=http://localhost:8002

# Demo mode: enables /api/v1/auth/demo + mock Solana anchoring when no funded wallet is configured
DEMO_MODE=true
