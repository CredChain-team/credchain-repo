# ─────────────────────────────────────────────────────────────
# CredChain Backend — environment variables
# Copy this file to ".env" and fill in real values.
# ─────────────────────────────────────────────────────────────

# HTTP server
PORT=5000

# Allowed cross-origin frontend (CORS)
CLIENT_ORIGIN=http://localhost:3000

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/credchain

# JSON Web Token signing secret
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google OAuth 2.0 (Sign in with Google — unified flow for all 3 roles)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must be exactly the GOOGLE_CALLBACK_URL below.
GOOGLE_CLIENT_ID=replace_me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_me_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Advanced systems
# Comma-separated emails allowed to run the Layer-4 issuer registry cross-match.
ADMIN_EMAILS=admin@credchain.io
# Shared secret the biometric-KYC provider must send as the x-kyc-secret header.
KYC_WEBHOOK_SECRET=replace_me_with_a_kyc_webhook_secret

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
# Path to the Devnet fee-payer wallet JSON (array of secret-key bytes).
# If unset, credential accept still works but skips the on-chain Memo write.
SOLANA_WALLET_PATH=./devnet-wallet.json

# Downstream AI microservices (proxied by the backend)
AI_CV_ENGINE_URL=http://localhost:8001
AI_INSIGHTS_ENGINE_URL=http://localhost:8002
